# Web styling editor (apps/web)
PORT=4317
# Bind host. Default 127.0.0.1 (local-only, no auth). Set 0.0.0.0 only behind a
# trusted reverse proxy / network.
WS_HOST=127.0.0.1
# Absolute path to the scores/ directory (defaults to the repo's scores/).
# WS_SCORES_DIR=/app/scores
# Verovio render concurrency. 0/unset = one toolkit + mutex (serialized renders).
# N>0 = a pool of N worker threads, each with its own toolkit → parallel renders
# (capped at 8). Recommended: number of CPU cores - 1.
# WS_RENDER_WORKERS=3
