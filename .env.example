# Web styling editor (apps/web)
PORT=4317
# Bind host. Default 127.0.0.1 (local-only, no auth). Set 0.0.0.0 only behind a
# trusted reverse proxy / network.
WS_HOST=127.0.0.1
# Absolute path to the scores/ directory (defaults to the repo's scores/).
# WS_SCORES_DIR=/app/scores
# Verovio render concurrency. Unset = a small worker pool (CPU cores - 1, max 4)
# so a multi-slide preview renders its slides in parallel — the default. Set a
# number to pin the pool size (max 8), or 0 to force one toolkit + mutex.
# WS_RENDER_WORKERS=3
