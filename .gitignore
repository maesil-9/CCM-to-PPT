# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Test / coverage
coverage/
.vitest/

# Generated artifacts (deterministic outputs, regenerate from fixtures)
/out/
/.tmp/
*.local.pptx
# Per-score generated output (keep inputs/options, drop generated artifacts)
scores/*/out/
# User-provided scores may be copyrighted — keep them local. Only the synthetic
# `demo` example is tracked in the repo.
scores/*/
!scores/demo/
!scores/demo/**

# Env / secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OMC / agent orchestration state (not project code)
.omc/
_writedocs.mjs
