{
  "name": "worship-score-ai",
  "version": "0.0.0",
  "private": true,
  "description": "WorshipScore AI — convert worship sheet music into structured ScoreIR and generate re-typeset worship PPTX (staff, melody, rhythm, lyrics).",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "m1": "pnpm --filter @worship-score/pipeline run m1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
